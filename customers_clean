view/table
CREATE OR REPLACE VIEW customers_clean AS
SELECT
  customer_id,
  CAST(age AS INT) AS age,
  CAST(tenure_months AS INT) AS tenure_months,
  CAST(credit_score AS INT) AS credit_score,
  TRIM(geography) AS geography,
  TRIM(gender) AS gender,
  CAST(balance AS DECIMAL(18,2)) AS balance,
  CAST(num_products AS INT) AS num_products,
  CAST(has_credit_card AS INT) AS has_credit_card,
  CAST(is_active_member AS INT) AS is_active_member,
  CAST(estimated_salary AS DECIMAL(18,2)) AS estimated_salary,
  CAST(exited AS INT) AS exited
FROM customers_raw
WHERE customer_id IS NOT NULL;
